@page "/settings"
@using GitGet.Core.Interfaces
@using GitGet.WebUI.Services
@inject IGitGetSettings AppSettings
@inject ICacheService CacheService
@inject AppState AppState
@inject LocalizationService L

<div class="page-header">
    <h1 class="page-title">@L.T("settings.title")</h1>
    <p class="page-subtitle">@L.T("settings.subtitle")</p>
</div>

<div class="settings-section">
    <h3>@L.T("settings.download_section")</h3>
    <div class="form-group">
        <label class="form-label">@L.T("settings.download_path")</label>
        <div class="flex gap-2">
            <input class="form-input" value="@AppSettings.DownloadPath" readonly />
            <button class="btn" @onclick="SelectDownloadPath">@L.T("settings.select_folder")</button>
        </div>
        <div class="form-hint">@L.T("settings.download_path_hint")</div>
    </div>

    <div class="form-group">
        <label class="form-label">@L.T("settings.max_concurrent")</label>
        <input class="form-input" type="number" min="1" max="10" value="@AppSettings.MaxConcurrentDownloads"
               @onchange="OnMaxConcurrentChanged" />
        <div class="form-hint">@L.T("settings.max_concurrent_hint")</div>
    </div>
</div>

<div class="settings-section">
    <h3>@L.T("settings.appearance")</h3>
    <div class="form-group">
        <label class="form-label">@L.T("settings.theme")</label>
        <div class="theme-toggle" @onclick="ToggleTheme">
            <span class="theme-toggle-label @(AppState.IsDarkMode ? "" : "theme-toggle-active")">@L.T("settings.theme_light")</span>
            <span class="theme-toggle-label @(AppState.IsDarkMode ? "theme-toggle-active" : "")">@L.T("settings.theme_dark")</span>
        </div>
    </div>

    <div class="form-group">
        <label class="form-label">@L.T("settings.language")</label>
        <select class="form-input" @bind="_language" @bind:event="onchange" @bind:after="AfterLanguageChanged">
            <option value="zh">@L.T("settings.lang_zh")</option>
            <option value="en">@L.T("settings.lang_en")</option>
        </select>
    </div>
</div>

<div class="settings-section">
    <h3>@L.T("settings.cache_section")</h3>
    <div class="flex gap-2 items-center">
        <button class="btn" @onclick="ClearCache">@L.T("settings.clear_cache")</button>
        <span style="color:var(--muted);font-size:13px;">
            @L.T("settings.cache_desc")
            @if (_cacheSize > 0)
            {
                <text>（@_cacheSize 条记录）</text>
            }
        </span>
    </div>
</div>

<div class="settings-section">
    <h3>@L.T("settings.about_section")</h3>
    <div style="font-size:14px;color:var(--muted);line-height:1.8;">
        <p><strong>GitGet</strong> v1.0</p>
        <p>@L.T("settings.about_desc")</p>
        <p>@L.T("settings.tech_stack")</p>
        <p><a href="https://github.com" target="_blank" style="color:var(--primary);">GitHub 主页</a></p>
    </div>
</div>

@code {
    private string _language = "zh";
    private long _cacheSize;

    protected override void OnInitialized()
    {
        _language = L.Lang;
        L.OnLanguageChanged += () => InvokeAsync(StateHasChanged);
    }

    protected override async Task OnInitializedAsync()
    {
        await AppSettings.LoadAsync();
        _cacheSize = await CacheService.GetCacheSizeAsync();
    }

    private async void ToggleTheme()
    {
        AppState.IsDarkMode = !AppState.IsDarkMode;
        AppSettings.Theme = AppState.IsDarkMode ? "dark" : "light";
        await AppSettings.SaveAsync();
    }

    private async void AfterLanguageChanged()
    {
        L.SetLanguage(_language);
        AppSettings.Language = _language;
        await AppSettings.SaveAsync();
    }

    private void SelectDownloadPath()
    {
        using var dialog = new FolderBrowserDialog
        {
            Description = "选择下载目录",
            SelectedPath = AppSettings.DownloadPath,
            ShowNewFolderButton = true,
        };

        if (dialog.ShowDialog() == System.Windows.Forms.DialogResult.OK)
        {
            AppSettings.DownloadPath = dialog.SelectedPath;
            _ = AppSettings.SaveAsync();
            StateHasChanged();
        }
    }

    private async Task OnMaxConcurrentChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var value) && value is >= 1 and <= 10)
        {
            AppSettings.MaxConcurrentDownloads = value;
            await AppSettings.SaveAsync();
        }
    }

    private async Task ClearCache()
    {
        await CacheService.ClearAllAsync();
        _cacheSize = 0;
    }

    private static string FormatSize(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024L * 1024) return $"{bytes / 1024.0:F1} KB";
        return $"{bytes / (1024.0 * 1024.0):F1} MB";
    }

    public void Dispose()
    {
        L.OnLanguageChanged -= () => InvokeAsync(StateHasChanged);
    }
}