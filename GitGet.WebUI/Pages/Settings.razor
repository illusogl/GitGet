@page "/settings"
@using GitGet.Core.Interfaces
@inject IGitGetSettings AppSettings
@inject ICacheService CacheService

<div class="page-header">
    <h1 class="page-title">⚙️ 设置</h1>
    <p class="page-subtitle">配置 GitGet 的下载和外观选项</p>
</div>

<div class="settings-section">
    <h3>📁 下载设置</h3>
    <div class="form-group">
        <label class="form-label">默认下载路径</label>
        <div class="flex gap-2">
            <input class="form-input" value="@AppSettings.DownloadPath" readonly />
            <button class="btn" @onclick="SelectDownloadPath">选择</button>
        </div>
        <div class="form-hint">所有下载文件将保存到此目录</div>
    </div>

    <div class="form-group">
        <label class="form-label">最大并发下载数</label>
        <input class="form-input" type="number" min="1" max="10" value="@AppSettings.MaxConcurrentDownloads"
               @onchange="OnMaxConcurrentChanged" />
        <div class="form-hint">同时下载的最大任务数（1-10）</div>
    </div>
</div>

<div class="settings-section">
    <h3>🎨 外观设置</h3>
    <div class="form-group">
        <label class="form-label">主题</label>
        <select class="form-input" @bind="_theme">
            <option value="dark">深色（默认）</option>
            <option value="light">浅色</option>
            <option value="system">跟随系统</option>
        </select>
    </div>

    <div class="form-group">
        <label class="form-label">语言</label>
        <select class="form-input" @bind="_language">
            <option value="zh">简体中文</option>
            <option value="en">English</option>
        </select>
    </div>
</div>

<div class="settings-section">
    <h3>🧹 缓存管理</h3>
    <div class="flex gap-2 items-center">
        <button class="btn" @onclick="ClearCache">🗑 清除缓存</button>
        <span style="color:var(--text-muted);font-size:13px;">
            清除本地缓存的仓库和 Release 数据
            @if (_cacheSize > 0)
            {
                <text>（约 @FormatSize(_cacheSize)）</text>
            }
        </span>
    </div>
</div>

<div class="settings-section">
    <h3>ℹ️ 关于</h3>
    <div style="font-size:14px;color:var(--text-secondary);line-height:1.8;">
        <p><strong>GitGet</strong> v1.0</p>
        <p>GitHub Release 应用商店客户端</p>
        <p>技术栈：C# + .NET 9 + Blazor + Photino</p>
        <p><a href="https://github.com" target="_blank" style="color:var(--accent);">GitHub 主页</a></p>
    </div>
</div>

@code {
    private string _theme = "dark";
    private string _language = "zh";
    private long _cacheSize;

    protected override async Task OnInitializedAsync()
    {
        await AppSettings.LoadAsync();
        _cacheSize = await CacheService.GetCacheSizeAsync();
    }

    private void SelectDownloadPath()
    {
        using var dialog = new FolderBrowserDialog
        {
            Description = "选择下载目录",
            SelectedPath = AppSettings.DownloadPath,
            ShowNewFolderButton = true,
        };

        if (dialog.ShowDialog() == System.Windows.Forms.DialogResult.OK)
        {
            AppSettings.DownloadPath = dialog.SelectedPath;
            _ = AppSettings.SaveAsync();
            StateHasChanged();
        }
    }

    private async Task OnMaxConcurrentChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var value) && value is >= 1 and <= 10)
        {
            AppSettings.MaxConcurrentDownloads = value;
            await AppSettings.SaveAsync();
        }
    }

    private async Task ClearCache()
    {
        await CacheService.ClearAllAsync();
        _cacheSize = 0;
    }

    private static string FormatSize(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024L * 1024) return $"{bytes / 1024.0:F1} KB";
        return $"{bytes / (1024.0 * 1024.0):F1} MB";
    }
}