@page "/search"
@using GitGet.Core.Models
@using GitGet.Core.Interfaces
@inject IGitHubApiClient GitHubClient
@inject AppState AppState
@inject LocalizationService L
@inject NavigationManager Navigation

<div class="page-header">
    <h1 class="page-title">@L.T("search.title")</h1>
    <p class="page-subtitle">@L.T("search.subtitle")</p>
</div>

<div class="search-bar">
    <input class="search-input" @bind="_query" @bind:event="oninput"
           @onkeydown="HandleKeyDown" placeholder="@L.T("search.placeholder")" />
    <button class="btn btn-primary" @onclick="DoSearch">@L.T("search.btn")</button>
</div>

@if (_isSearching)
{
    <div class="loading">@L.T("search.searching")</div>
}
else if (_hasSearched && _results.Count == 0)
{
    <div class="empty-state">
        <div class="empty-state-title">@L.T("search.no_results")</div>
        <div class="empty-state-desc">@L.T("search.no_results_desc")</div>
    </div>
}
else if (_results.Count > 0)
{
    <div class="mb-2" style="color:var(--muted);font-size:14px;">
        @string.Format(L.T("search.result_count"), _totalCount)
    </div>
    <div class="card-grid">
        @foreach (var repo in _results)
        {
            <ProjectCard Repo="repo" OnClick="() => GoToDetail(repo)" L="L" />
        }
    </div>
}

@code {
    private string _query = "";
    private List<Repository> _results = new();
    private int _totalCount = 0;
    private bool _isSearching = false;
    private bool _hasSearched = false;

    protected override void OnInitialized()
    {
        L.OnLanguageChanged += () => InvokeAsync(StateHasChanged);
    }

    private async Task DoSearch()
    {
        if (string.IsNullOrWhiteSpace(_query)) return;

        _isSearching = true;
        _hasSearched = true;
        _results.Clear();

        try
        {
            var results = await GitHubClient.SearchRepositoriesAsync(_query, sort: "stars", perPage: 30);
            _results = results;
            _totalCount = results.Count;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Search failed: {ex.Message}");
        }
        finally
        {
            _isSearching = false;
        }
    }

    private void HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            _ = DoSearch();
        }
    }

    private void GoToDetail(Repository repo)
    {
        AppState.SelectedRepository = repo;
        Navigation.NavigateTo("/detail");
    }

    public void Dispose()
    {
        L.OnLanguageChanged -= () => InvokeAsync(StateHasChanged);
    }
}