@page "/search"
@using GitGet.Core.Models
@using GitGet.Core.Interfaces
@inject IGitHubApiClient GitHubClient
@inject AppState AppState
@inject NavigationManager Navigation

<div class="page-header">
    <h1 class="page-title">🔍 搜索项目</h1>
    <p class="page-subtitle">在 GitHub 上搜索你感兴趣的开源项目</p>
</div>

<div class="search-bar">
    <input class="search-input" @bind="_query" @bind:event="oninput"
           @onkeydown="HandleKeyDown" placeholder="输入关键词，如: vscode, react, dotnet..." />
    <button class="btn btn-primary" @onclick="DoSearch">搜索</button>
</div>

@if (_isSearching)
{
    <div class="loading">正在搜索...</div>
}
else if (_hasSearched && _results.Count == 0)
{
    <div class="empty-state">
        <div class="empty-state-icon">🔍</div>
        <div class="empty-state-title">未找到结果</div>
        <div class="empty-state-desc">尝试更换关键词或检查网络连接</div>
    </div>
}
else if (_results.Count > 0)
{
    <div class="mb-2" style="color:var(--text-muted);font-size:14px;">
        找到约 @_totalCount 个结果
    </div>
    <div class="card-grid">
        @foreach (var repo in _results)
        {
            <ProjectCard Repo="repo" OnClick="() => GoToDetail(repo)" />
        }
    </div>
}

@code {
    private string _query = "";
    private List<Repository> _results = new();
    private int _totalCount = 0;
    private bool _isSearching = false;
    private bool _hasSearched = false;

    private async Task DoSearch()
    {
        if (string.IsNullOrWhiteSpace(_query)) return;

        _isSearching = true;
        _hasSearched = true;
        _results.Clear();

        try
        {
            var results = await GitHubClient.SearchRepositoriesAsync(_query, sort: "stars", perPage: 30);
            _results = results;
            _totalCount = results.Count;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"搜索失败: {ex.Message}");
        }
        finally
        {
            _isSearching = false;
        }
    }

    private void HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            _ = DoSearch();
        }
    }

    private void GoToDetail(Repository repo)
    {
        AppState.SelectedRepository = repo;
        Navigation.NavigateTo("/detail");
    }
}
