@page "/"
@using GitGet.Core.Models
@using GitGet.Core.Interfaces
@inject IGitHubApiClient GitHubClient
@inject IAssetMatcherService Matcher
@inject IDownloadService DownloadService
@inject AppState AppState
@inject NavigationManager Navigation

<div class="page-header">
    <h1 class="page-title">🔥 热门项目</h1>
    <p class="page-subtitle">发现 GitHub 上最受欢迎的开源项目</p>
</div>

@if (_isLoading)
{
    <div class="loading">正在加载...</div>
}
else if (_repos.Count == 0)
{
    <div class="empty-state">
        <div class="empty-state-icon">📭</div>
        <div class="empty-state-title">暂无数据</div>
        <div class="empty-state-desc">请检查网络连接或稍后重试</div>
    </div>
}
else
{
    <div class="card-grid">
        @foreach (var repo in _repos)
        {
            <ProjectCard Repo="repo" OnClick="() => GoToDetail(repo)" />
        }
    </div>
}

@code {
    private List<Repository> _repos = new();
    private bool _isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadTrending();
    }

    private async Task LoadTrending()
    {
        _isLoading = true;
        try
        {
            var results = await GitHubClient.SearchRepositoriesAsync("stars:>10000", sort: "stars", perPage: 20);
            _repos = results;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"加载热门项目失败: {ex.Message}");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void GoToDetail(Repository repo)
    {
        AppState.SelectedRepository = repo;
        Navigation.NavigateTo("/detail");
    }
}
