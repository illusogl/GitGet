@page "/"
@using GitGet.Core.Models
@using GitGet.Core.Interfaces
@inject ITrendingService TrendingService
@inject AppState AppState
@inject LocalizationService L
@inject NavigationManager Navigation

<div class="page-header">
    <h1 class="page-title">@L.T("home.title")</h1>
    <p class="page-subtitle">@L.T("home.subtitle")</p>
</div>

<div class="time-tabs">
    <button class="time-tab @(_timeRange == "daily" ? "time-tab-active" : "")" @onclick="SwitchToDaily">@L.T("home.today")</button>
    <button class="time-tab @(_timeRange == "monthly" ? "time-tab-active" : "")" @onclick="SwitchToMonthly">@L.T("home.month")</button>
    <button class="time-tab @(_timeRange == "yearly" ? "time-tab-active" : "")" @onclick="SwitchToYearly">@L.T("home.year")</button>
    <button class="time-tab @(_timeRange == "all" ? "time-tab-active" : "")" @onclick="SwitchToAll">@L.T("home.all")</button>
</div>

@if (_isLoading && _repos.Count == 0)
{
    <div class="loading">@L.T("home.loading")</div>
}
else if (_repos.Count == 0)
{
    <div class="empty-state">
        <div class="empty-state-title">@L.T("home.empty_title")</div>
        <div class="empty-state-desc">@L.T("home.empty_desc")</div>
    </div>
}
else
{
    <div class="card-grid">
        @foreach (var repo in _repos)
        {
            <ProjectCard Repo="repo" OnClick="() => GoToDetail(repo)" L="L" />
        }
    </div>

    @if (_hasMore)
    {
        <div style="text-align:center;padding:var(--sp-xl) 0;">
            @if (_isLoadingMore)
            {
                <span style="color:var(--muted);">@L.T("home.loading")</span>
            }
            else
            {
                <button class="btn" @onclick="LoadMore">加载更多</button>
            }
        </div>
    }
    else
    {
        <div class="text-muted" style="text-align:center;padding:var(--sp-lg);">— 已显示全部结果 —</div>
    }
}

@code {
    private List<Repository> _repos = new();
    private bool _isLoading = true;
    private bool _isLoadingMore;
    private string _timeRange = "all";
    private int _currentPage = 1;
    private bool _hasMore = true;

    protected override void OnInitialized()
    {
        L.OnLanguageChanged += () => InvokeAsync(StateHasChanged);
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadTrending();
    }

    private async Task SwitchToDaily() => await SwitchTimeRange("daily");
    private async Task SwitchToMonthly() => await SwitchTimeRange("monthly");
    private async Task SwitchToYearly() => await SwitchTimeRange("yearly");
    private async Task SwitchToAll() => await SwitchTimeRange("all");

    private async Task SwitchTimeRange(string range)
    {
        if (_timeRange == range) return;
        _timeRange = range;
        _currentPage = 1;
        _hasMore = true;
        await LoadTrending();
    }

    private async Task LoadTrending()
    {
        _isLoading = true;
        _repos.Clear();
        StateHasChanged();
        try
        {
            var repos = await TrendingService.GetTrendingReposAsync(_timeRange, perPage: 30);
            _repos = repos;
            _hasMore = repos.Count >= 30;
            _currentPage = 1;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"加载热门项目失败: {ex.Message}");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task LoadMore()
    {
        _isLoadingMore = true;
        StateHasChanged();
        try
        {
            _currentPage++;
            var repos = await TrendingService.GetTrendingReposAsync(_timeRange, page: _currentPage, perPage: 30);
            _hasMore = repos.Count >= 30;
            _repos.AddRange(repos);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"加载更多失败: {ex.Message}");
        }
        finally
        {
            _isLoadingMore = false;
        }
    }

    private void GoToDetail(Repository repo)
    {
        AppState.SelectedRepository = repo;
        Navigation.NavigateTo("/detail");
    }

    public void Dispose()
    {
        L.OnLanguageChanged -= () => InvokeAsync(StateHasChanged);
    }
}