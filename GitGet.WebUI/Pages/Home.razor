@page "/"
@using GitGet.Core.Models
@using GitGet.Core.Interfaces
@inject ITrendingService TrendingService
@inject AppState AppState
@inject NavigationManager Navigation

<div class="page-header">
    <h1 class="page-title">热门项目</h1>
    <p class="page-subtitle">发现 GitHub 上最受欢迎的开源项目</p>
</div>

<div class="time-tabs">
    <button class="time-tab @(_timeRange == "daily" ? "time-tab-active" : "")" @onclick="SwitchToDaily">今天</button>
    <button class="time-tab @(_timeRange == "monthly" ? "time-tab-active" : "")" @onclick="SwitchToMonthly">本月</button>
    <button class="time-tab @(_timeRange == "yearly" ? "time-tab-active" : "")" @onclick="SwitchToYearly">今年</button>
    <button class="time-tab @(_timeRange == "all" ? "time-tab-active" : "")" @onclick="SwitchToAll">历史</button>
</div>

@if (_isLoading)
{
    <div class="loading">正在加载...</div>
}
else if (_repos.Count == 0)
{
    <div class="empty-state">
        <div class="empty-state-title">暂无数据</div>
        <div class="empty-state-desc">请检查网络连接或稍后重试</div>
    </div>
}
else
{
    <div class="card-grid">
        @foreach (var repo in _repos)
        {
            <ProjectCard Repo="repo" OnClick="() => GoToDetail(repo)" />
        }
    </div>
}

@code {
    private List<Repository> _repos = new();
    private bool _isLoading = true;
    private string _timeRange = "all";

    protected override async Task OnInitializedAsync()
    {
        await LoadTrending();
    }

    private async Task SwitchToDaily() => await SwitchTimeRange("daily");
    private async Task SwitchToMonthly() => await SwitchTimeRange("monthly");
    private async Task SwitchToYearly() => await SwitchTimeRange("yearly");
    private async Task SwitchToAll() => await SwitchTimeRange("all");

    private async Task SwitchTimeRange(string range)
    {
        if (_timeRange == range) return;
        _timeRange = range;
        await LoadTrending();
    }

    private async Task LoadTrending()
    {
        _isLoading = true;
        StateHasChanged();
        try
        {
            _repos = await TrendingService.GetTrendingReposAsync(_timeRange, perPage: 20);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"加载热门项目失败: {ex.Message}");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void GoToDetail(Repository repo)
    {
        AppState.SelectedRepository = repo;
        Navigation.NavigateTo("/detail");
    }
}