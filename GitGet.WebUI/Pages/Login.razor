@page "/login"
@using GitGet.WebUI.Services
@inject LocalizationService L
@inject NavigationManager Navigation

<div class="login-container">
    <div class="login-card">
        <h1 class="login-title">@L.T("login.title")</h1>
        <p class="login-subtitle">@L.T("login.subtitle")</p>

        <div class="login-placeholder">
            <p>@L.T("login.wip")</p>
            <p style="margin-top:8px;">@L.T("login.features_desc")</p>
            <ul style="text-align:left;margin:12px auto 0;max-width:300px;font-size:12px;color:var(--muted);">
                <li>@L.T("login.feature_star")</li>
                <li>@L.T("login.feature_rec")</li>
                <li>@L.T("login.feature_cloud")</li>
            </ul>
        </div>

        <p class="text-muted" style="font-size:13px;">
            @L.T("login.offline")
        </p>
    </div>
</div>