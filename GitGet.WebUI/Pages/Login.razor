@page "/login"
@implements IDisposable
@using GitGet.Core.Models
@using GitGet.Core.Interfaces
@using GitGet.WebUI.Services
@inject IAuthService AuthService
@inject IGitHubApiClient GitHubClient
@inject AppState AppState
@inject LocalizationService L
@inject NavigationManager Navigation

@if (!AuthService.IsLoggedIn)
{
    @* ===== Not logged in: Login form ===== *@
    <div class="login-container">
        <div class="login-card" style="max-width:480px;">
            <h1 class="login-title">@L.T("login.title")</h1>
            <p class="login-subtitle">@L.T("login.subtitle")</p>

            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <div style="background:var(--surface-card);border-radius:var(--radius-md);padding:12px;margin-bottom:16px;">
                    <p style="color:var(--error);font-size:13px;">@_errorMessage</p>
                </div>
            }

            <div style="margin-bottom:20px;">
                <h3 style="font-size:14px;font-weight:600;margin-bottom:8px;color:var(--ink);">
                    @L.T("login.token_method")
                </h3>
                <p style="font-size:12px;color:var(--muted);margin-bottom:8px;line-height:1.5;">
                    @L.T("login.token_hint")
                    <a href="https://github.com/settings/tokens/new?scopes=user,repo&description=GitGet" target="_blank" style="color:var(--primary);">@L.T("login.token_link")</a>
                </p>
                <div style="display:flex;gap:8px;">
                    <input class="form-input" style="flex:1;" @bind="_tokenInput" placeholder="ghp_xxxxxxxxxxxx" />
                    <button class="btn btn-primary" @onclick="LoginWithToken" disabled="@_isLoading">
                        @if (_isLoading) { @L.T("login.connecting") } else { @L.T("login.token_submit") }
                    </button>
                </div>
            </div>

            <div style="text-align:center;color:var(--muted-soft);font-size:13px;margin:16px 0;">@L.T("login.or")</div>

            <button class="btn btn-secondary" style="width:100%;margin-bottom:8px;" @onclick="StartDeviceFlow" disabled="@_isLoading">
                @L.T("login.device_flow")
            </button>

            @if (_flowStage == "deviceCode")
            {
                <div style="text-align:center;margin-top:16px;padding:16px;background:var(--surface-card);border-radius:var(--radius-md);">
                    <p style="font-size:13px;margin-bottom:8px;color:var(--muted);">
                        @L.T("login.step1") @L.T("login.step2")
                    </p>
                    <code style="font-family:var(--font-code);font-size:28px;font-weight:700;letter-spacing:6px;color:var(--primary);">@_userCode</code>
                    <p style="font-size:12px;color:var(--muted-soft);margin-top:8px;">
                        @L.T("login.enter_code_at")
                        <a href="@_verificationUri" target="_blank" style="color:var(--primary);">@_verificationUri</a>
                    </p>
                    <button class="btn btn-primary btn-sm" style="margin-top:8px;" @onclick="CheckAuth">
                        @L.T("login.done_auth")
                    </button>
                </div>
            }
        </div>
    </div>
}
else
{
    @* ===== Logged in: Profile page ===== *@
    <div class="page-header" style="margin-bottom:var(--sp-xl);">
        <h1 class="page-title">@L.T("login.profile")</h1>
    </div>

    @if (_profileLoading)
    {
        <div class="loading">@L.T("home.loading")</div>
    }
    else
    {
        @* User info card *@
        <div class="profile-header">
            @if (!string.IsNullOrEmpty(_user?.AvatarUrl))
            {
                <img class="profile-avatar" src="@_user.AvatarUrl" alt="@_user.Login" />
            }
            <div class="profile-info">
                <div class="profile-name">@(_user?.Name ?? _user?.Login ?? "GitHub User")</div>
                <div class="profile-login">
                    <a href="https://github.com/@_user?.Login" target="_blank" style="color:var(--primary);text-decoration:none;">
                        @_user.Login
                    </a>
                </div>
                @if (!string.IsNullOrEmpty(_user?.Bio))
                {
                    <div class="profile-bio">@_user.Bio</div>
                }
                <div class="profile-stats">
                    <span>@L.T("login.followers"): @(_user?.Followers ?? 0)</span>
                    <span>@L.T("login.following"): @(_user?.Following ?? 0)</span>
                    <span>@L.T("login.repos"): @(_user?.PublicRepos ?? 0)</span>
                </div>
            </div>
            <div style="margin-left:auto;">
                <button class="btn" style="color:var(--error);border-color:var(--error);" @onclick="Logout">
                    @L.T("login.logout")
                </button>
            </div>
        </div>

        @* Two-column: My Repos + Starred Repos *@
        <div class="profile-grid">
            @* My Repos *@
            <div class="profile-section">
                <h3 class="profile-section-title">
                    @L.T("login.my_repos")
                    @if (_repos.Count > 0)
                    {
                        <span style="font-size:13px;font-weight:400;color:var(--muted);">(@_repos.Count)</span>
                    }
                </h3>
                @if (_reposLoading)
                {
                    <p class="text-muted" style="padding:16px;">@L.T("home.loading")</p>
                }
                else if (_repos.Count == 0)
                {
                    <p class="text-muted" style="padding:16px;">@L.T("login.no_repos")</p>
                }
                else
                {
                    <div class="profile-repo-list">
                        @foreach (var repo in _repos.Take(20))
                        {
                            <div class="profile-repo-item" @onclick="() => GoToRepo(repo)">
                                <span class="profile-repo-name">@repo.FullName</span>
                                <div style="display:flex;align-items:center;gap:12px;font-size:12px;color:var(--muted-soft);">
                                    @if (!string.IsNullOrEmpty(repo.Language))
                                    {
                                        <span style="display:flex;align-items:center;gap:4px;">
                                            <span class="language-dot" style="background-color:@GetLanguageColor(repo.Language)"></span> @repo.Language
                                        </span>
                                    }
                                    <span>⭐ @FormatNumber(repo.Stars)</span>
                                    <span>⑂ @FormatNumber(repo.Forks)</span>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>

            @* Starred Repos *@
            <div class="profile-section">
                <h3 class="profile-section-title">
                    @L.T("login.starred")
                    @if (_starred.Count > 0)
                    {
                        <span style="font-size:13px;font-weight:400;color:var(--muted);">(@_starred.Count)</span>
                    }
                </h3>
                @if (_starredLoading)
                {
                    <p class="text-muted" style="padding:16px;">@L.T("home.loading")</p>
                }
                else if (_starred.Count == 0)
                {
                    <p class="text-muted" style="padding:16px;">@L.T("login.no_starred")</p>
                }
                else
                {
                    <div class="profile-repo-list">
                        @foreach (var repo in _starred.Take(20))
                        {
                            <div class="profile-repo-item" @onclick="() => GoToRepo(repo)">
                                <span class="profile-repo-name">@repo.FullName</span>
                                <div style="display:flex;align-items:center;gap:12px;font-size:12px;color:var(--muted-soft);">
                                    @if (!string.IsNullOrEmpty(repo.Language))
                                    {
                                        <span style="display:flex;align-items:center;gap:4px;">
                                            <span class="language-dot" style="background-color:@GetLanguageColor(repo.Language)"></span> @repo.Language
                                        </span>
                                    }
                                    <span>⭐ @FormatNumber(repo.Stars)</span>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    }
}

@code {
    // Login state
    private string _tokenInput = "";
    private string _errorMessage = "";
    private bool _isLoading;
    private string _flowStage = "";
    private string _userCode = "";
    private string _verificationUri = "";
    private string _deviceCode = "";
    private int _interval = 5;

    // Profile state
    private GitHubUser? _user;
    private List<Repository> _repos = new();
    private List<Repository> _starred = new();
    private bool _profileLoading = true;
    private bool _reposLoading = true;
    private bool _starredLoading = true;

    protected override async Task OnInitializedAsync()
    {
        L.OnLanguageChanged += () => InvokeAsync(StateHasChanged);
        if (AuthService.IsLoggedIn)
        {
            await LoadProfile();
        }
    }

    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender && AuthService.IsLoggedIn && _profileLoading)
        {
            _ = LoadProfile();
        }
    }

    private async Task LoadProfile()
    {
        _profileLoading = true;
        try
        {
            _user = await GitHubClient.GetUserAsync();

            // Load repos and starred in parallel
            var reposTask = LoadMyRepos();
            var starredTask = LoadStarred();
            await Task.WhenAll(reposTask, starredTask);
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to load profile: {ex.Message}";
        }
        finally
        {
            _profileLoading = false;
            StateHasChanged();
        }
    }

    private async Task LoadMyRepos()
    {
        _reposLoading = true;
        try
        {
            if (!string.IsNullOrEmpty(_user?.Login))
            {
                var results = await GitHubClient.SearchRepositoriesAsync($"user:{_user.Login}", sort: "updated", perPage: 20);
                _repos = results;
            }
        }
        catch { }
        finally
        {
            _reposLoading = false;
        }
    }

    private async Task LoadStarred()
    {
        _starredLoading = true;
        try
        {
            if (!string.IsNullOrEmpty(_user?.Login))
            {
                var results = await GitHubClient.GetStarredReposAsync(_user.Login, perPage: 20);
                _starred = results;
            }
        }
        catch { }
        finally
        {
            _starredLoading = false;
        }
    }

    private async Task LoginWithToken()
    {
        var token = _tokenInput.Trim();
        if (string.IsNullOrEmpty(token) || !token.StartsWith("ghp_"))
        {
            _errorMessage = L.T("login.invalid_token");
            StateHasChanged();
            return;
        }

        _isLoading = true;
        _errorMessage = "";
        StateHasChanged();

        try
        {
            var accessToken = token; // capture before pass
            AuthService.SetToken(accessToken);
            GitHubClient.SetAccessToken(accessToken);
            if (await AuthService.ValidateTokenAsync(accessToken))
            {
                AppState.CurrentUserLogin = "github_user";
                await LoadProfile();
            }
            else
            {
                AuthService.Logout();
                _errorMessage = L.T("login.invalid_token");
            }
        }
        catch
        {
            AuthService.Logout();
            _errorMessage = L.T("login.please_retry");
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private async Task StartDeviceFlow()
    {
        _isLoading = true;
        _errorMessage = "";
        _flowStage = "";
        StateHasChanged();

        try
        {
            var deviceCode = await AuthService.RequestDeviceCodeAsync();
            _userCode = deviceCode.UserCode;
            _verificationUri = deviceCode.VerificationUri;
            _deviceCode = deviceCode.DeviceCode;
            _interval = Math.Max(deviceCode.Interval, 5);
            _flowStage = "deviceCode";
        }
        catch (Exception ex)
        {
            _errorMessage = $"{L.T("login.error")}: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private async Task CheckAuth()
    {
        if (string.IsNullOrEmpty(_deviceCode)) return;
        _errorMessage = L.T("login.connecting");
        StateHasChanged();

        for (int i = 0; i < 5; i++)
        {
            try
            {
                var (status, token) = await AuthService.PollForTokenAsync(_deviceCode, _interval, default);
                if (status == DeviceFlowStatus.Authorized && token != null)
                {
                    GitHubClient.SetAccessToken(token.AccessToken);
                    AppState.CurrentUserLogin = "github_user";
                    await LoadProfile();
                    return;
                }
                if (status != DeviceFlowStatus.Pending)
                {
                    _errorMessage = status switch
                    {
                        DeviceFlowStatus.Expired => L.T("login.expired"),
                        DeviceFlowStatus.Denied => L.T("login.denied"),
                        _ => L.T("login.unknown_error"),
                    };
                    StateHasChanged();
                    return;
                }
            }
            catch
            {
                _errorMessage = L.T("login.please_retry");
                StateHasChanged();
                return;
            }
        }
        _errorMessage = L.T("login.still_pending");
        StateHasChanged();
    }

    private void GoToRepo(Repository repo)
    {
        AppState.SelectedRepository = repo;
        Navigation.NavigateTo("/detail");
    }

    private void Logout()
    {
        AuthService.Logout();
        AppState.CurrentUserLogin = null;
        _user = null;
        _repos.Clear();
        _starred.Clear();
        _flowStage = "";
    }

    private static string FormatNumber(int n) => n >= 1000 ? $"{(n / 1000.0):F1}k" : n.ToString();

    private static string GetLanguageColor(string lang) => lang.ToLower() switch
    {
        "c#" => "#178600", "python" => "#3572A5", "javascript" => "#f1e05a", "typescript" => "#3178c6",
        "java" => "#b07219", "go" => "#00ADD8", "rust" => "#dea584", "c++" => "#f34b7d",
        "c" => "#555555", "html" => "#e34c26", "css" => "#563d7c", "shell" => "#89e051",
        "ruby" => "#701516", "swift" => "#ffac45", "kotlin" => "#A97BFF", _ => "#8b949e"
    };

    public void Dispose()
    {
        L.OnLanguageChanged -= () => InvokeAsync(StateHasChanged);
    }
}