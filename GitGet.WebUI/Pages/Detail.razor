@page "/detail"
@using GitGet.Core.Models
@using GitGet.Core.Interfaces
@using Markdig
@inject IGitHubApiClient GitHubClient
@inject IAssetMatcherService Matcher
@inject IDownloadService DownloadService
@inject IGitGetSettings AppSettings
@inject ICacheService CacheService
@inject AppState AppState
@inject LocalizationService L
@inject NavigationManager Navigation

@if (AppState.SelectedRepository == null)
{
    <div class="empty-state">
        <div class="empty-state-title">@L.T("detail.not_selected")</div>
        <div class="empty-state-desc">@L.T("detail.not_selected_desc")</div>
        <button class="btn btn-primary mt-3" @onclick='() => Navigation.NavigateTo("/")'>@L.T("detail.back_home")</button>
    </div>
    return;
}

@{
    var repo = AppState.SelectedRepository;
}

<div class="detail-layout">

    <div class="detail-info-card">
        <div class="detail-title">
            <a href="https://github.com/@repo.FullName" target="_blank">@repo.FullName</a>
        </div>
        <div class="detail-description">@repo.Description</div>
        <div class="detail-stats">
            <span>⭐ @repo.Stars.ToString("N0")</span>
            <span>⑂ @repo.Forks.ToString("N0")</span>
            <span>📝 @repo.OpenIssues @L.T("detail.issues")</span>
            @if (!string.IsNullOrEmpty(repo.Language))
            {
                <span><span class="language-dot" style="background-color:@GetLanguageColor(repo.Language)"></span> @repo.Language</span>
            }
            @if (!string.IsNullOrEmpty(repo.License))
            {
                <span>📜 @repo.License</span>
            }
        </div>
        @if (repo.Topics.Count > 0)
        {
            <div class="topics">
                @foreach (var topic in repo.Topics)
                {
                    <span class="topic-tag">@topic</span>
                }
            </div>
        }
    </div>

    <div class="detail-tabs">
        <button class="detail-tab @(_activeTab == "readme" ? "detail-tab-active" : "")" @onclick='() => SwitchTab("readme")'>
            @L.T("detail.readme_tab")
        </button>
        <button class="detail-tab @(_activeTab == "releases" ? "detail-tab-active" : "")" @onclick='() => SwitchTab("releases")'>
            @L.T("detail.releases_tab")
        </button>
    </div>

    @if (_activeTab == "readme")
    {
        <div class="readme-placeholder">
            <div class="readme-placeholder-header">
                <span>README.md</span>
                <span style="margin-left:auto;font-size:12px;color:var(--on-dark-soft);">
                    @repo.DefaultBranch ?? "main"
                </span>
            </div>
            @if (_isReadmeLoading)
            {
                <div class="readme-placeholder-body">
                    <p>@L.T("detail.loading_readme")</p>
                </div>
            }
            else if (_readmeError != null)
            {
                <div class="readme-placeholder-body">
                    <p style="color:var(--error);">@_readmeError</p>
                    <button class="btn btn-sm mt-2" @onclick="LoadReadme">@L.T("detail.retry")</button>
                </div>
            }
            else if (_readmeHtml != null)
            {
                <div class="readme-content markdown-body">
                    @((MarkupString)_readmeHtml)
                </div>
            }
            else
            {
                <div class="readme-placeholder-body">
                    <p>@L.T("detail.no_readme")</p>
                </div>
            }
        </div>
    }

    @if (_activeTab == "releases")
    {
        @if (_isLoading)
        {
            <div class="loading">@L.T("detail.loading_releases")</div>
        }
        else if (_releases.Count == 0)
        {
            <div class="empty-state">
                <div class="empty-state-title">@L.T("detail.no_releases")</div>
                <div class="empty-state-desc">@L.T("detail.no_releases_desc")</div>
            </div>
        }
        else
        {
            <div class="release-list">
                @foreach (var release in _releases)
                {
                    <div class="release-item">
                        <div class="release-header" @onclick="() => ToggleRelease(release.Id)">
                            <div class="flex items-center gap-3">
                                <span class="release-title">@release.TagName</span>
                                @if (release.Prerelease)
                                {
                                    <span class="release-badge">@L.T("detail.prerelease")</span>
                                }
                            </div>
                            <div class="flex items-center gap-4">
                                <span class="release-date">@release.PublishedAt.ToString("yyyy-MM-dd")</span>
                                <span style="color:var(--muted-soft);">@(_expandedReleaseId == release.Id ? "▼" : "▶")</span>
                            </div>
                        </div>

                        @if (_expandedReleaseId == release.Id)
                        {
                            <div class="release-body">
                                @if (!string.IsNullOrEmpty(release.Body))
                                {
                                    <div class="release-notes">@release.Body</div>
                                }

                                @if (release.Assets.Count > 0)
                                {
                                <div style="font-size:14px;font-weight:500;color:var(--muted);margin-bottom:8px;">
                                    @string.Format(L.T("detail.download_assets"), release.Assets.Count)
                                </div>
                                    <div class="asset-list">
                                        @foreach (var asset in release.Assets)
                                        {
                                            var isRecommended = _recommendedAssets.TryGetValue(asset.Id, out var score) && score > 0;
                                            <div class="asset-item">
                                                <div class="asset-info">
                                                    <span class="asset-name">@asset.Name</span>
                                                    <span class="asset-size">@FormatSize(asset.Size)</span>
                                                    @if (isRecommended)
                                                    {
                                                        <span class="asset-recommended">@L.T("detail.recommended")</span>
                                                    }
                                                </div>
                                                <div class="asset-actions">
                                                    <button class="btn btn-primary btn-sm" @onclick="() => DownloadAsset(asset, repo.FullName)">
                                                        ↓ @L.T("detail.download")
                                                    </button>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <div style="color:var(--muted-soft);font-size:14px;padding:8px 0;">
                                        @L.T("detail.no_assets")
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }
            </div>
        }
    }
</div>

@code {
    private List<Release> _releases = new();
    private Dictionary<long, int> _recommendedAssets = new();
    private bool _isLoading = true;
    private long? _expandedReleaseId;
    private string _activeTab = "readme";

    private string? _readmeContent;
    private string? _readmeHtml;
    private bool _isReadmeLoading;
    private string? _readmeError;
    private bool _readmeLoaded;

    protected override void OnInitialized()
    {
        L.OnLanguageChanged += () => InvokeAsync(StateHasChanged);
    }

    protected override async Task OnInitializedAsync()
    {
        if (AppState.SelectedRepository == null)
            return;

        var readmeTask = LoadReadme();
        var releasesTask = LoadReleases();

        await Task.WhenAll(readmeTask, releasesTask);
    }

    private void SwitchTab(string tab)
    {
        _activeTab = tab;
        if (tab == "readme" && !_readmeLoaded)
        {
            _ = LoadReadmeAndRefresh();
        }
    }

    private async Task LoadReadmeAndRefresh()
    {
        await LoadReadme();
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadReadme()
    {
        var repo = AppState.SelectedRepository!;
        _isReadmeLoading = true;
        _readmeError = null;

        var cacheKey = $"readme:{repo.Owner}/{repo.Name}";

        try
        {
            _readmeContent = await CacheService.GetOrSetAsync(
                cacheKey,
                async () =>
                {
                    var content = await GitHubClient.GetReadmeContentAsync(repo.Owner, repo.Name);
                    if (content == null)
                        return string.Empty;

                    if (content.Length > 200_000)
                        content = content[..200_000] + "\n\n... (内容过长，已截断)";

                    return content;
                },
                TimeSpan.FromHours(1)
            );

            _readmeLoaded = true;
            _isReadmeLoading = false;

            if (!string.IsNullOrEmpty(_readmeContent))
            {
                var htmlCacheKey = $"readme:html:{repo.Owner}/{repo.Name}";
                var cachedHtml = await CacheService.GetOrSetAsync<string?>(
                    htmlCacheKey,
                    () => Task.FromResult<string?>(null),
                    TimeSpan.FromHours(1));

                if (!string.IsNullOrEmpty(cachedHtml))
                {
                    _readmeHtml = cachedHtml;
                }
                else
                {
                    var content = _readmeContent;
                    _ = Task.Run(async () =>
                    {
                        var html = Markdown.ToHtml(content);
                        html = html.Replace("<a ", "<a target=\"_blank\" rel=\"noopener noreferrer\" ");

                        await CacheService.GetOrSetAsync(
                            htmlCacheKey,
                            () => Task.FromResult(html),
                            TimeSpan.FromHours(1));

                        await InvokeAsync(() =>
                        {
                            _readmeHtml = html;
                            StateHasChanged();
                        });
                    });
                }
            }
            else
            {
                _readmeError = L.T("detail.no_readme");
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            _readmeError = string.Format(L.T("detail.load_failed"), ex.Message);
            _isReadmeLoading = false;
            StateHasChanged();
        }
    }

    private async Task LoadReleases()
    {
        var repo = AppState.SelectedRepository!;
        _isLoading = true;
        try
        {
            var releases = await GitHubClient.GetReleasesAsync(repo.Owner, repo.Name, perPage: 10);
            _releases = releases;

            foreach (var release in releases)
            {
                var recs = Matcher.GetRecommendedAssets(release.Assets);
                foreach (var kv in recs)
                {
                    _recommendedAssets[kv.Key] = kv.Value;
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"加载 Release 失败: {ex.Message}");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void ToggleRelease(long id)
    {
        _expandedReleaseId = _expandedReleaseId == id ? null : id;
    }

    private async Task DownloadAsset(ReleaseAsset asset, string repoFullName)
    {
        var downloadDir = AppSettings.DownloadPath;

        var progress = new Progress<DownloadProgress>(p =>
        {
            InvokeAsync(() =>
            {
                Console.WriteLine($"[{p.TaskId}] {p.Percent:F1}% {p.Status}");
            });
        });

        try
        {
            var task = await DownloadService.StartDownloadAsync(
                asset.DownloadUrl, asset.Name, repoFullName, downloadDir, progress);
            AppState.ActiveDownloadCount++;
            Navigation.NavigateTo("/downloads");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"下载失败: {ex.Message}");
        }
    }

    private static string FormatSize(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024L * 1024) return $"{bytes / 1024.0:F1} KB";
        return $"{bytes / (1024.0 * 1024.0):F1} MB";
    }

    private static string GetLanguageColor(string lang) => lang.ToLower() switch
    {
        "c#" => "#178600",
        "python" => "#3572A5",
        "javascript" => "#f1e05a",
        "typescript" => "#3178c6",
        "java" => "#b07219",
        "go" => "#00ADD8",
        "rust" => "#dea584",
        "c++" => "#f34b7d",
        "c" => "#555555",
        "html" => "#e34c26",
        "css" => "#563d7c",
        "shell" => "#89e051",
        "ruby" => "#701516",
        "swift" => "#ffac45",
        "kotlin" => "#A97BFF",
        _ => "#8b949e"
    };
}