@inherits LayoutComponentBase
@using Microsoft.JSInterop
@inject LocalizationService L
@inject AppState AppState

<div class="app-container">
    <div class="sidebar">
        <div class="brand">
            <span class="brand-title">GitGet</span>
        </div>

        <nav class="nav-menu">
            <NavLink class="nav-item" href="/" Match="NavLinkMatch.All">
                <span class="nav-text">@L.T("nav.home")</span>
            </NavLink>
            <NavLink class="nav-item" href="/search">
                <span class="nav-text">@L.T("nav.search")</span>
            </NavLink>
            <NavLink class="nav-item" href="/downloads">
                <span class="nav-text">@L.T("nav.downloads")</span>
                @if (DownloadCount > 0)
                {
                    <span class="nav-badge">@DownloadCount</span>
                }
            </NavLink>
            <NavLink class="nav-item" href="/login">
                <span class="nav-text">@L.T("nav.login")</span>
            </NavLink>
            <NavLink class="nav-item" href="/settings">
                <span class="nav-text">@L.T("nav.settings")</span>
            </NavLink>
        </nav>

        <div class="sidebar-footer">
            <span class="version">GitGet v1.1</span>
        </div>
    </div>

    <div class="main-content">
        @Body
    </div>
</div>

@code {
    [Inject] private IJSRuntime JS { get; set; } = default!;

    private int DownloadCount => AppState.ActiveDownloadCount;

    protected override async Task OnInitializedAsync()
    {
        AppState.OnDownloadCountChanged += OnDownloadCountChanged;
        AppState.OnThemeChanged += OnThemeChangedHandler;
        L.OnLanguageChanged += OnLanguageChangedHandler;
        await SetThemeAsync(AppState.IsDarkMode);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await SetThemeAsync(AppState.IsDarkMode);
        }
    }

    private void OnDownloadCountChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private void OnLanguageChangedHandler()
    {
        InvokeAsync(StateHasChanged);
    }

    private async void OnThemeChangedHandler()
    {
        await SetThemeAsync(AppState.IsDarkMode);
    }

    private async Task SetThemeAsync(bool isDark)
    {
        await JS.InvokeVoidAsync("setTheme", isDark);
    }

    public void Dispose()
    {
        AppState.OnDownloadCountChanged -= OnDownloadCountChanged;
        AppState.OnThemeChanged -= OnThemeChangedHandler;
        L.OnLanguageChanged -= OnLanguageChangedHandler;
    }
}