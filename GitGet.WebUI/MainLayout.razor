@inherits LayoutComponentBase
@using Microsoft.JSInterop

<div class="app-container">
    <div class="sidebar">
        <div class="brand">
            <span class="brand-title">GitGet</span>
        </div>

        <nav class="nav-menu">
            <NavLink class="nav-item" href="/" Match="NavLinkMatch.All">
                <span class="nav-text">首页</span>
            </NavLink>
            <NavLink class="nav-item" href="/search">
                <span class="nav-text">搜索</span>
            </NavLink>
            <NavLink class="nav-item" href="/downloads">
                <span class="nav-text">下载</span>
                @if (DownloadCount > 0)
                {
                    <span class="nav-badge">@DownloadCount</span>
                }
            </NavLink>
            <NavLink class="nav-item" href="/login">
                <span class="nav-text">登录</span>
            </NavLink>
            <NavLink class="nav-item" href="/settings">
                <span class="nav-text">设置</span>
            </NavLink>
        </nav>

        <div class="sidebar-footer">
            <span class="version">GitGet v1.0</span>
        </div>
    </div>

    <div class="main-content">
        @Body
    </div>
</div>

@code {
    [Inject] private AppState AppState { get; set; } = default!;
    [Inject] private IJSRuntime JS { get; set; } = default!;

    private int DownloadCount => AppState.ActiveDownloadCount;

    protected override async Task OnInitializedAsync()
    {
        AppState.OnDownloadCountChanged += OnDownloadCountChanged;
        AppState.OnThemeChanged += OnThemeChangedHandler;
        // Apply current theme on startup
        await SetThemeAsync(AppState.IsDarkMode);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await SetThemeAsync(AppState.IsDarkMode);
        }
    }

    private void OnDownloadCountChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private async void OnThemeChangedHandler()
    {
        await SetThemeAsync(AppState.IsDarkMode);
    }

    private async Task SetThemeAsync(bool isDark)
    {
        await JS.InvokeVoidAsync("setTheme", isDark);
    }

    public void Dispose()
    {
        AppState.OnDownloadCountChanged -= OnDownloadCountChanged;
        AppState.OnThemeChanged -= OnThemeChangedHandler;
    }
}
